{
  "name": "zois-core",
  "version": "1.2.1",
  "description": "The core for the my mods, which contains a shared code reused in all my mods",
  "scripts": {
    "build": "node scripts/build.mjs"
  },
  "author": "Zoi",
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/types/core.d.ts"
    },
    "./messaging": {
      "import": "./dist/messaging.js",
      "types": "./dist/types/messaging.d.ts"
    },
    "./mod-sdk": {
      "import": "./dist/modSdk.js",
      "types": "./dist/types/modSdk.d.ts"
    },
    "./ui": {
      "import": "./dist/ui.js",
      "types": "./dist/types/ui.d.ts"
    },
    "./shard-modules": {
      "import": "./dist/shard-modules/index.js",
      "types": "./dist/types/shard-modules/index.d.ts"
    },
    "./shards": {
      "import": "./dist/shards/index.js",
      "types": "./dist/types/shards/index.d.ts"
    },
    "./wardrobe": {
      "import": "./dist/wardrobe.js",
      "types": "./dist/types/wardrobe.d.ts"
    },
    "./dialogs": {
      "import": "./dist/dialogs.js",
      "types": "./dist/types/dialogs.d.ts"
    },
    "./toasts": {
      "import": "./dist/toasts.js",
      "types": "./dist/types/toasts.d.ts"
    },
    "./validation": {
      "import": "./dist/validation.js",
      "types": "./dist/types/validation.d.ts"
    },
    "./logging": {
      "import": "./dist/logging.js",
      "types": "./dist/types/logging.d.ts"
    },
    "./localization": {
      "import": "./dist/localization.js",
      "types": "./dist/types/localization.d.ts"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "bondage-club-mod-sdk": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "lucide": "^1.24.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "bc-stubs": "130.0.0-Beta.1",
    "esbuild": "^0.28.1",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  }
}